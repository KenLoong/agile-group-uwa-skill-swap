# =============================================================================
# UWA Skill-Swap — environment template (copy to .env and fill in)
# =============================================================================
# Never commit real secrets. Markers: use local values only.
#
# FLASK / APP
# -----------
# Required outside automated tests. Generate a long random value for local runs.
# Example generator:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
PUBLIC_BASE_URL=http://127.0.0.1:5000
FLASK_ENV=development
DATABASE_URL=sqlite:///database.db

# EMAIL VERIFICATION (see docs/EMAIL_VERIFICATION.md)
# ---------------------------------------------------
# Master switch: set false only in early HTML-only milestones.
EMAIL_VERIFICATION_ENABLED=true

# When true, Flask-Login must refuse login until email_confirmed is set.
REQUIRE_VERIFIED_EMAIL_TO_LOGIN=false

# From header and dev transport
EMAIL_FROM=UWA Skill-Swap <no-reply@uwa.local>
EMAIL_BACKEND=console

# SMTP — only when EMAIL_BACKEND=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# SELENIUM (optional, for tests/test_selenium when added)
# ------------------------------------------------------
CHROMEDRIVER_PATH=
CHROME_BIN=
